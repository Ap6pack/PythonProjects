# Copy to .env and fill in. Never commit real credentials.

# PostGIS connection (matches docker-compose defaults)
DATABASE_URL=postgresql://geoask:geoask@localhost:5432/geoask

# Pilot region to load (Phase 0). Keep it to one metro so iteration stays fast.
PILOT_REGION=Portland, OR

# Routing engine for the isochrone primitive. If set, isochrones follow the road
# network; if unset, the primitive falls back to a labelled approximation.
# VALHALLA_URL=http://localhost:8002

# LLM orchestration (Phase 2) — not used yet.
# ANTHROPIC_API_KEY=
